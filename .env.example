# ==============================================
# TRH Solutions Field Service — Environment Variables
# ==============================================
# Copy this file to .env and fill in your values.
# On Render, set these in the Dashboard → Environment tab.

# ── Database ──
# Render auto-sets this when you link a PostgreSQL database.
# For local dev, use SQLite (leave blank) or a local Postgres instance.
DATABASE_URL=

# ── Flask ──
# Secret key for session signing. On Render, auto-generated via render.yaml.
SECRET_KEY=change-me-to-a-random-string

# Set to 'production' on Render (auto-set via render.yaml).
FLASK_ENV=development

# ── AI Chat (optional) ──
# Required only if you want the AI assistant feature.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
