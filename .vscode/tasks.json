{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start FieldServicePro",
      "type": "shell",
      "command": "${workspaceFolder}/venv/Scripts/python",
      "args": ["${workspaceFolder}/web/app.py"],
      "isBackground": true,
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Serving Flask app.*$",
          "endsPattern": "^.*Running on http.*$"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "close": false
      }
    }
  ]
}
